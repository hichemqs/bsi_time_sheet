<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

<tree string="Soumissions" create="false" edit="false" delete="false">
    <field name="name" string="N° Soumission"/>
    <field name="opportunity_id" string="Projet Client"/>
    <field name="partner_id" string="Nom du Client"/>
    <field name="date_order" string="Date"/>
</tree>

    
<form string="Soumission" edit="false">
    <header>
        <field name="state" widget="statusbar"
            statusbar_visible="draft,sent,sale"/>
    </header>
    <sheet>
        <div class="oe_title">
            <h1>
                <field name="name"/>
            </h1>
        </div>
        <group string="Informations Générales">
            <group>
                <field name="opportunity_id" string="Projet Client"/>
                <field name="partner_id" string="Nom du Client"
                    widget="res_partner_many2one"/>
                <field name="date_order" string="Date"/>
                <field name="validity_date" string="Expiration"/>
                <field name="payment_term_id"/>
            </group>
            <group>
                <field name="company_id" invisible="1"/>
                <field name="tax_country_id" invisible="1"/>
                <field name="currency_id" invisible="1"/>
            </group>
        </group>
        <group string="Équipe de Charge">
            <group>
                <field name="user_id" string="Responsable"
                    widget="many2one_avatar_user"/>
                <field name="team_id" string="Équipe de Vente"/>
                <field name="client_order_ref" string="Référence Client"/>
                <field name="tag_ids" string="Étiquettes"
                    widget="many2many_tags"
                    options="{'color_field': 'color'}"/>
            </group>
            <group>
                <field name="require_signature"/>
                <field name="require_payment"/>
                <field name="origin" string="Source"/>
            </group>
        </group>
    </sheet>
</form>
    
</odoo>