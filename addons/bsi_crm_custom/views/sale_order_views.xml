        <field name="name">sale.order.search.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_view_search_inherit_quotation"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='my_quotation']" position="attributes">
                <attribute name="string">Mes soumissions</attribute>
            </xpath>
            <xpath expr="//filter[@name='my_quotation']" position="after">
                <filter string="Mes soumissions en cours" name="soumissions_en_cours" domain="[('user_id', '=', uid), ('stag_id', 'in', ['demande', 'planification', 'missing_info', 'estimation', 'a_configurer'])]"/>
            </xpath>
            <xpath expr="//filter[@name='sales']" position="attributes">
                <attribute name="string">Contrat</attribute>
                <attribute name="domain">[('stag_id', '=', 'contrat')]</attribute>
            </xpath>
            <xpath expr="//filter[@name='sales']" position="after">
                <filter string="Est perdu" name="quotation_lost" domain="[('stag_id', '=', 'perdu')]"/>
                <filter string="Est abandonné" name="quotation_abandoned" domain="[('stag_id', '=', 'abandonnee')]"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="string">Soumission</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="opportunity_id" string="Projet"/>
                <field name="contrat"/>
                <field name="paying_customer_id"/>
            </xpath>
            <xpath expr="//filter[@name='filter_create_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- <xpath expr="//filter[@name='filter_create_date']" position="replace">
                <filter string="Date de creation OAE" name="filter_create_date" date="create_date_oae"/>
            </xpath> -->
        </field>
    </record>


    <record id="sale_order_view_search_inherit_hide_date_groupby" model="ir.ui.view">
        <field name="name">sale.order.search.inherit.hide.date.groupby</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
