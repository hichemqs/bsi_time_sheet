<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_view_hierarchy" model="ir.ui.view">
    <field name="name">sale.order.view.hierarchy</field>
    <field name="model">sale.order</field>
    <field name="arch" type="xml">
        <hierarchy child_field="order_child_ids" draggable="1" icon="fa-users">
            <field name="user_id"/>
            <field name="name"/>
            <field name="partner_id"/>
            <field name="paying_customer_id"/>
            <field name="user_image_128"/>
            <field name="stag_id"/>

            <templates>
                <t t-name="hierarchy-box">
                    <div class="o_hierarchy_node_header d-flex justify-content-center pb-4">
                        <field name="user_image_128"
                               widget="background_image"
                               preview_image="user_image_128"
                               options="{'zoom': true, 'zoom_delay': 1000}"/>
                    </div>

                    <div class="o_hierarchy_node_body d-flex flex-column text-center p-2">
                        <div>
                            <span t-att-class="{
                                'text-warning fw-bold': record.stag_id.raw_value == 'soumission',
                                'text-success fw-bold': record.stag_id.raw_value == 'contrat',
                                'fw-bold': !['soumission','contrat'].includes(record.stag_id.raw_value)
                            }">
                                <field name="name"/>
                            </span>
                            <br/>
                            <span class="fw-bold">Client : </span> <field name="partner_id"/><br/>
                            <span class="fw-bold">Client P : </span> <field name="paying_customer_id"/><br/>
                        </div>
                    </div>
                </t>
            </templates>
        </hierarchy>
    </field>
</record>


    
