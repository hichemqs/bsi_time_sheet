<odoo>

    <record id="view_contact_role_tree" model="ir.ui.view">
        <field name="name">contact.role.tree</field>
        <field name="model">contact.role</field>
        <field name="arch" type="xml">
            <tree>
                <field name="complete_name" string="Rôle de contact"/>
            </tree>
        </field>
    </record>

    <record id="view_contact_role_form" model="ir.ui.view">
        <field name="name">contact.role.form</field>
        <field name="model">contact.role</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_contact_role" model="ir.actions.act_window">
        <field name="name">roles des contacts</field>
        <field name="res_model">contact.role</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem 
        id="menu_contact_role" 
        name="Rôle de contact" 
        parent="contacts.res_partner_menu_config"  
        action="action_contact_role"
        sequence="4"
    />

</odoo>
