    <record id="partner_view_buttons_hide_is_published" model="ir.ui.view">
    <field name="name">partner.view.buttons.hide.is_published</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="website_partner.view_partners_form_website"/>
    <field name="arch" type="xml">
        <xpath expr="//div[@name='button_box']/field[@name='is_published']" position="attributes">
            <attribute name="invisible">1</attribute>
        </xpath>
    </field>
