    <record id="view_partner_base_vat_form_inherit" model="ir.ui.view">
    <field name="model">res.partner</field>
    <field name="name">view.partner.base.vat.form.inherit</field>
    <field name="priority">16</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='vat']" position="after">
            <field name="perform_vies_validation" invisible="1"/>
            <label for="vat" string="Tax ID"/>
            <div name="vat_vies_container"/>
        </xpath>
        
        <xpath expr="//div[@name='vat_vies_container']" position="attributes">
            <attribute name="invisible">1</attribute>
        </xpath>

        <xpath expr="//label[@for='vat']" position="attributes">
            <attribute name="invisible">1</attribute>
        </xpath>
    </field>
</record>



    <record id="res_partner_form_inherit_header" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.header</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">15</field>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                 <div class="header_buttons d-flex gap-2 mb-2">
                     <field name="sales_director_user_id" invisible="1"/>
                     <button name="action_open_close_partner"
                            string="Fermer le client"
                            type="object"
                            class="btn btn-primary"
                            modifiers="{'invisible': ['|', ('is_closed', '=', False), ('credit_blocked', '=', False)]}"/>

                    <button name="action_open_credit_block_wizard"
                            type="object"
                            class="btn btn-secondary"
                            context="{'block_type': 'credit'}"
                            invisible="credit_blocked and (user_id != uid and sales_director_user_id != uid)">
                        <field name="credit_block_button_label" readonly="1"/>
                    </button>

                    <button name="action_open_sale_block_wizard"
                            type="object"
                            class="btn btn-secondary"
                            context="{'block_type': 'sale'}"
                            invisible="sale_blocked and (user_id != uid and sales_director_user_id != uid)">
                        <field name="sale_block_button_label" readonly="1"/>
                    </button>
                </div>
            </xpath>
        </field>
    </record>


</odoo>
