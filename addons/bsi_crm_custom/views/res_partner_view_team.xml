<record id="res_partner_view_team_1" model="ir.ui.view">
    <field name="name">res.partner.inherit.stat.button</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">
        <xpath expr="//button[@name='action_view_sale_order']" position="after">

    <!-- Bouton Toutes les soumissions -->
    <button type="object"
            name="action_view_all_soumissions"
            class="btn oe_stat_button btn-outline-secondary flex-grow-1"
            style="cursor: pointer;">
        <i class="o_button_icon fa fa-fw fa-list"/>
        <div class="o_field_widget o_readonly_modifier o_field_statinfo">
            <field name="soumission_count" widget="statinfo" class="o_stat_infoo_stat_value"/>
            <!-- <span class="o_stat_text">Toutes les soumissions</span> -->
        </div>
    </button>

    <!-- Soumissions en cours -->
    <button type="object"
            name="action_view_soumission_stage"
            class="btn oe_stat_button btn-outline-secondary flex-grow-1"
            style="cursor: pointer;">
        <i class="o_button_icon fa fa-fw fa-paper-plane"/>
        <div class="o_field_widget o_readonly_modifier o_field_statinfo">
            <field name="soumission_count_soumission" widget="statinfo" class="o_stat_info o_stat_value"/>
            <!-- <span class="o_stat_text">Nombre Soumissions en cours</span> -->
        </div>
    </button>

    <!-- Contrats -->
    <button type="object"
            name="action_view_contrat_stage"
            class="btn oe_stat_button btn-outline-secondary flex-grow-1"
            style="cursor: pointer;">
        <i class="o_button_icon fa fa-fw fa-file-signature"/>
        <div class="o_field_widget o_readonly_modifier o_field_statinfo">
            <field name="soumission_count_contrat" widget="statinfo" class="o_stat_info o_stat_value"/>
            <!-- <span class="o_stat_text">Nombre de contrat</span> -->
        </div>
    </button>

</xpath>

        <xpath expr="//button[@name='action_view_sale_order']" position="attributes">
