<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_partner_view_team_inherit" model="ir.ui.view">
        <field name="name">res.partner.view.team.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="sales_team.res_partner_view_team"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='sales_purchases']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='sales_purchases']//field[@name='team_id']" position="before">
                <field name="sales_director_id" widget="many2one_avatar_user"/>
            </xpath>
            <xpath expr="//widget[@name='web_ribbon']" position="after">
                <widget name="web_ribbon" title="Closed" bg_color="text-bg-danger" invisible="not is_closed"/>
            </xpath>
<!--            <xpath expr="//field[@name='category_id']" position="after">-->
<!--                <field name="approval_required"/>-->
<!--            </xpath>-->
            <xpath expr="//page[@name='sales_purchases']" position="before">
                <page string="Categorization" invisible="parent_id">
                    <group>
<!--                        <field name="reminder"/>-->
                        <field name="categ_last_update_date" readonly="1"/>
                        <field name="is_closed" invisible="1"/>
                    </group>
                    <group string="Categorization history">
                        <field name="categ_history_ids" nolabel="1" colspan="2">
                            <tree no_open="True">
                                <field name="potential_recurrence" optional="show"/>
                                <field name="is_proportion_above_80" string="Util. Barette +80%"  optional="show"/>
                                <field name="openings_per_year" string="Nb portes/année" optional="show"/>
                                <field name="customer_category" string="Categorie" optional="show"/>
                                <field name="last_update_year" optional="show"/>
                                <field name="customer_id" optional="show"/>
                                <field name="user_id" widget="many2one_avatar_user" optional="show"/>
                                <field name="updated_on" optional="show"/>
                            </tree>
                        </field>
                    </group>
                </page>
            </xpath>
			<xpath expr="//field[@name='category_id']" position="before">
                <field name="customer_categ_id"/>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="sync_status"  widget="badge" decoration-success="sync_status == 'active'" decoration-danger="sync_status == 'inactive'"/>
            </xpath>
            <xpath expr="//group[@name='misc']/field[@name='industry_id']" position="after">
                <field name="closure_reason_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="res_partner_form_inherit_ca_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.ca.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="l10n_ca.res_partner_form_inherit_ca"/>
        <field name="arch" type="xml">
<xpath expr="//field[@name='image_1920']" position="after">
    <field name="credit_blocked" invisible="1"/>
     <!-- <field name="employee_ids" invisible="1"/> -->
    <field name="sale_blocked" invisible="1"/>
    <div class="float-end mx-4">
        <div class="fs-6 badge rounded-pill fw-bold text-bg-info ms-2" invisible="is_closed or sap_number">Prospect</div>
        <div class="fs-6 badge rounded-pill fw-bold text-bg-info ms-2" invisible="is_closed or not sap_number">Client</div>
        <div class="fs-6 badge rounded-pill fw-bold text-bg-info ms-2" invisible="1">Contact Client</div>
        <!-- <div class="fs-6 badge rounded-pill fw-bold text-bg-info ms-2" invisible="not employee_ids">Employé</div> -->
        <div class="fs-6 badge rounded-pill fw-bold text-bg-danger ms-2" invisible="not credit_blocked">Bloqué crédit</div>
        <div class="fs-6 badge rounded-pill fw-bold text-bg-danger ms-2" invisible="not sale_blocked">Bloqué vente</div>
    </div>
</xpath>
            <xpath expr="//field[@name='l10n_ca_pst']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_ca_pst']" position="after">
                <!-- <field name="sap_number"/> -->
                <!-- <label for="customer_category" string="Category" invisible="parent_id"/> -->
                <!-- <div class="o_row" style="width: 70% !important;" invisible="parent_id">
                    <field name="customer_category" readonly="1" options="{'no_open':True,'no_create': True}"/>
                    <button name="action_update_category" type="object" string=" Update Category" class="btn-link mb-1 px-0" icon="fa-arrow-right"/>
                </div> -->

                
                 <!-- <field name="date_de_creation" string="Date de Création"/> -->
                <!-- <field name="create_date" string="Customer create date" position="attributes"/> -->
            </xpath>

            <xpath expr="//field[@name='phone']" position="before">
                <field name="user_id" widget="many2one_avatar_user" domain="[('share', '=', False)]"/>
                <field name="sales_director_id" widget="many2one_avatar_user"/>
                <field string="Termes de paiement" name="property_payment_term_id" options="{'no_open': True, 'no_create': True}" groups="account.group_account_invoice,account.group_account_readonly"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_property_form_inherit" model="ir.ui.view">
        <field name="name">view.partner.property.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.view_partner_property_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='accounting']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='accounting_disabled']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

