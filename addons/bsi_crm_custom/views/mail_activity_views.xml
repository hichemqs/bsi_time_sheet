<odoo>
    <record id="view_my_activities_tree" model="ir.ui.view">
        <field name="name">mail.activity.tree.my</field>
        <field name="model">mail.activity</field>
        <field name="arch" type="xml">
<tree create="false" edit="false">
    <button name="action_open_related_document" type="object" string="Ouvrir" icon="fa-external-link"/>
    <field name="res_name" string="Document"/>
    <field name="summary" readonly="1"/>
    <field name="activity_type_id" readonly="1"/>
    <field name="date_deadline" readonly="1"/>
</tree>

        </field>
    </record>

    <record id="action_my_activities" model="ir.actions.act_window">
        <field name="name">Mes Activités</field>
        <field name="res_model">mail.activity</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_my_activities_tree"/>
        <field name="domain">[
            ('user_id', '=', uid),
            ('res_model', 'in', ['project.task', 'sale.order'])
        ]</field>
    </record>

    <menuitem id="menu_my_activities"
              name="Mes Activités"
              parent="crm.crm_activity_report_menu"
              action="action_my_activities"
              sequence="5"/>

</odoo>