<odoo>
    <record id="view_city_tree_inherit" model="ir.ui.view">
        <field name="name">view.city.tree.inherit</field>
        <field name="model">res.city</field>
        <field name="inherit_id" ref="base_address_extended.view_city_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state_id']" position="after">
                <field name="nom_mrc"/>
                <field name="region_administrative"/>
            </xpath>
        </field>
    </record>
    <record id="address_street_extended_city_form_inherit" model="ir.ui.view">
        <field name="name">address.street.extended.city.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_address_extended.address_street_extended_city_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='city_id']" position="attributes">
                <attribute name="string">Ville</attribute>
            </xpath>
        </field>
    </record>
</odoo>
