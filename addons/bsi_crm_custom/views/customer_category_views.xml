<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_customer_category_tree" model="ir.ui.view">
        <field name="name">view.customer.category.tree</field>
        <field name="model">res.partner.customer.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="type"/>
            </tree>
        </field>
    </record>

    <record id="view_customer_category_from" model="ir.ui.view">
        <field name="name">view.customer.category.form</field>
        <field name="model">res.partner.customer.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="type"/>
                            <field name="client_marchand"/>
                            <field name="is_default"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_customer_category" model="ir.actions.act_window">
        <field name="name">Type de client</field>
        <field name="res_model">res.partner.customer.category</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_customer_category"
              name="Type de client"
              sequence="1"
              parent="crm.crm_menu_config"
              action="action_customer_category"/>
</odoo>
