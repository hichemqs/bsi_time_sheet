<odoo>
    <data noupdate="1">
        <record id="ir_cron_mark_inactive_employees" model="ir.cron">
            <field name="name">Mark Inactive Employees</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model.cron_mark_inactive_employees()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(DateTime.now().replace(hour=0, minute=0, second=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>
    </data>
</odoo>
