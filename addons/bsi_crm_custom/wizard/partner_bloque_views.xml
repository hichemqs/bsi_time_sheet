<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_bloque_reason_wizard" model="ir.ui.view">
        <field name="name">view.partner.bloque.vente.wizard</field>
        <field name="model">partner.bloque.vente.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="reason"/>
                    </group>
                </sheet>
                <footer>
                    <button name="confirm_block" string="Confirm" type="object" class="oe_highlight"/>
                    <button special="cancel" string="Cancel" class="oe_link"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
