<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_department_form_inherit" model="ir.ui.view">
        <field name="name">view.department.form.inherit</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='manager_id']" position="after">
                <field name="responsible_id"/>
                <field name="code_dep"/>
                <field name="code_centre_cout"/>
                <field name="description_centre_cout"/>
                <field name="sector_id"/>
            </xpath>
            <xpath expr="//field[@name='parent_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='color']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='manager_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_department_tree_inherit" model="ir.ui.view">
        <field name="name">view.department.tree.inherit</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="responsible_id"/>
                <field name="code_dep"/>
                <field name="sector_id"/>
            </xpath>
            <xpath expr="//field[@name='parent_id']" position="replace"/>
            <xpath expr="//field[@name='color']" position="replace"/>
            <xpath expr="//field[@name='manager_id']" position="replace"/>
        </field>
    </record>

    <record id="view_department_kanban_inherit" model="ir.ui.view">
        <field name="name">view.department.kanban.inherit</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.hr_department_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="sector_id"/>
            </xpath>
            <xpath expr="//div[hasclass('o_kanban_card_header_title')]//field[@name='company_id']" position="after">
                <br/><field name="sector_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_department_filter_inherit" model="ir.ui.view">
        <field name="name">view.department.filter.inherit</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="code_dep"/>
            </xpath>
        </field>
    </record>
</odoo>
