<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_situation_emploi_premier_niveau_tree" model="ir.ui.view">
        <field name="name">situation.emploi.premier.niveau.tree</field>
        <field name="model">situation.emploi.premier.niveau</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_situation_emploi_premier_niveau_form" model="ir.ui.view">
        <field name="name">situation.emploi.premier.niveau.form</field>
        <field name="model">situation.emploi.premier.niveau</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <notebook>
                        <page string="Deuxieme niveau">
                            <field name="deuxieme_niveau_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_situation_emploi_premier_niveau" model="ir.actions.act_window">
        <field name="name">Situation d'emploi</field>
        <field name="res_model">situation.emploi.premier.niveau</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_situation_emploi_premier_niveau"
              name="Situation d'emploi"
              parent="hr.menu_human_resources_configuration"
              action="action_situation_emploi_premier_niveau"
              sequence="10"/>
</odoo>