<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_event_type_tree" model="ir.ui.view">
        <field name="name">view.hr.event.type.tree</field>
        <field name="model">hr.event.type</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_event_type_form" model="ir.ui.view">
        <field name="name">view.hr.event.type.form</field>
        <field name="model">hr.event.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_event_type" model="ir.actions.act_window">
        <field name="name">Type événement</field>
        <field name="res_model">hr.event.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_hr_event_type"
              name="Type événement"
              parent="hr.menu_human_resources_configuration"
              action="action_hr_event_type"/>
</odoo>
