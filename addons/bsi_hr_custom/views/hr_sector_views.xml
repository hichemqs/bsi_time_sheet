<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_sector_tree" model="ir.ui.view">
        <field name="name">view.hr.sector.tree</field>
        <field name="model">hr.sector</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="sector_no"/>
                <field name="company_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_sector_form" model="ir.ui.view">
        <field name="name">view.hr.sector.form</field>
        <field name="model">hr.sector</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sector_no"/>
                        <field name="company_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_sector" model="ir.actions.act_window">
        <field name="name">Secteur</field>
        <field name="res_model">hr.sector</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_hr_sector"
              name="Secteurs"
              parent="hr.menu_config_employee"
              sequence="3"
              action="action_hr_sector"/>
</odoo>